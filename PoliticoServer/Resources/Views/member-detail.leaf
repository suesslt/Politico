<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Politico - #(firstName) #(lastName)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        th.sortable { user-select: none; }
        .sort-arrows { display: inline-flex; vertical-align: middle; margin-left: 4px; font-size: 10px; gap: 1px; }
        .sort-arrows .arrow-up, .sort-arrows .arrow-down { color: #ccc; transition: color 0.15s; }
        .sort-arrows .arrow-up.active { color: #212529; }
        .sort-arrows .arrow-down.active { color: #212529; }
        .score-bar { height: 20px; border-radius: 4px; position: relative; }
        .score-bar-bg { background: #e9ecef; width: 100%; height: 100%; border-radius: 4px; position: relative; overflow: hidden; }
        .score-bar-fill { height: 100%; position: absolute; top: 0; border-radius: 4px; }
        .score-bar-center { position: absolute; left: 50%; top: 0; bottom: 0; width: 2px; background: #6c757d; z-index: 1; }
        .score-label { font-size: 12px; color: #6c757d; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark px-3">
        <span class="navbar-brand">Politico</span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Abmelden</a>
    </nav>

    <div class="container-fluid mt-3">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/sessions" id="backLink">Übersicht</a></li>
                <li class="breadcrumb-item active">#(firstName) #(lastName)</li>
            </ol>
        </nav>
        <script>
        (function() {
            var from = '#(backURL)';
            var link = document.getElementById('backLink');
            var tabMap = { 'parlamentarier': '#members', 'wortmeldungen': '#transcripts', 'geschaefte': '#businesses', 'kommissionen': '#committeesTab' };
            if (tabMap[from]) {
                link.href = '/sessions' + tabMap[from];
                link.textContent = from.charAt(0).toUpperCase() + from.slice(1);
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    sessionStorage.setItem('activeTab', tabMap[from]);
                    window.location.href = '/sessions';
                });
            }
        })();
        </script>

        <!-- Header -->
        <div class="d-flex align-items-center mb-3">
            <div>
                <h4 class="mb-0">#(firstName) #(lastName)</h4>
                <span class="badge" style="background-color:#(partyColor);color:#fff">#(party)</span>
                <span class="text-muted ms-2">#(councilName) &middot; #(cantonName)</span>
                #if(active):
                <span class="badge bg-success ms-2">Aktiv</span>
                #else:
                <span class="badge bg-secondary ms-2">Inaktiv</span>
                #endif
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#stammdaten" type="button">Stammdaten</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#details" type="button">Details</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#abstimmungen" type="button">Abstimmungen</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#wortmeldungen" type="button">Wortmeldungen <span class="badge bg-secondary">#(count(transcripts))</span></button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#kommissionen" type="button">Kommissionen</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#profil" type="button">Politisches Profil</button></li>
        </ul>

        <div class="tab-content mt-3">

            <!-- Tab: Stammdaten -->
            <div class="tab-pane fade show active" id="stammdaten" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr><th style="width:200px">Name</th><td>#(officialName)</td></tr>
                            <tr><th>Geschlecht</th><td>#(gender)</td></tr>
                            <tr><th>Geburtsdatum</th><td>#(dateOfBirth)</td></tr>
                            <tr><th>Zivilstand</th><td>#(maritalStatus)</td></tr>
                            <tr><th>Kinder</th><td>#(numberOfChildren)</td></tr>
                            <tr><th>Geburtsort</th><td>#(birthPlace)</td></tr>
                            <tr><th>Bürgerort</th><td>#(citizenship)</td></tr>
                            <tr><th>Nationalität</th><td>#(nationality)</td></tr>
                            <tr><th>Militärischer Rang</th><td>#(militaryRank)</td></tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr><th style="width:200px">Rat</th><td>#(councilName)</td></tr>
                            <tr><th>Kanton</th><td>#(cantonName) (#(canton))</td></tr>
                            <tr><th>Partei</th><td><span class="badge" style="background-color:#(partyColor);color:#fff">#(party)</span> #(partyName)</td></tr>
                            <tr><th>Fraktion</th><td>#(faction)</td></tr>
                            <tr><th>Wahl</th><td>#(dateElection)</td></tr>
                            <tr><th>Amtsantritt</th><td>#(dateJoining)</td></tr>
                            <tr><th>Beruf</th><td>#(occupation)</td></tr>
                            <tr><th>Arbeitgeber</th><td>#(employer)</td></tr>
                            <tr><th>Funktion</th><td>#(jobTitle)</td></tr>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Tab: Details -->
            <div class="tab-pane fade" id="details" role="tabpanel">
                <div class="row">
                    <div class="col-md-12">
                        #if(mandates != ""):
                        <h6>Mandate</h6>
                        <p class="text-muted small">#(mandates)</p>
                        #endif
                        #if(additionalMandate != ""):
                        <h6>Zusätzliche Mandate</h6>
                        <p class="text-muted small">#(additionalMandate)</p>
                        #endif
                        #if(additionalActivity != ""):
                        <h6>Zusätzliche Aktivitäten</h6>
                        <p class="text-muted small">#(additionalActivity)</p>
                        #endif

                        <h6 class="mt-4">Interessensbindungen</h6>
                        #if(count(interests) > 0):
                        <table class="table table-sm table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Organisation</th>
                                    <th>Typ</th>
                                    <th>Funktion</th>
                                    <th>Bezahlt</th>
                                </tr>
                            </thead>
                            <tbody>
                                #for(interest in interests):
                                <tr>
                                    <td>#(interest.name)</td>
                                    <td><small>#(interest.type)</small></td>
                                    <td><small>#(interest.function)</small></td>
                                    <td>#if(interest.paid):<span class="badge bg-success">Ja</span>#else:<span class="badge bg-secondary">Nein</span>#endif</td>
                                </tr>
                                #endfor
                            </tbody>
                        </table>
                        #else:
                        <p class="text-muted">Keine Interessensbindungen vorhanden.</p>
                        #endif
                    </div>
                </div>
            </div>

            <!-- Tab: Abstimmungen -->
            <div class="tab-pane fade" id="abstimmungen" role="tabpanel">
                #if(count(votings) > 0):
                <table class="table table-sm table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Nr.</th>
                            <th>Geschäft</th>
                            <th>Entscheid</th>
                        </tr>
                    </thead>
                    <tbody>
                        #for(voting in votings):
                        <tr>
                            <td><code class="text-muted">#(voting.businessNumber)</code></td>
                            <td>#(voting.billTitle)</td>
                            <td><span class="badge bg-#(voting.decisionClass)">#(voting.decision)</span></td>
                        </tr>
                        #endfor
                    </tbody>
                </table>
                #else:
                <p class="text-muted">Keine Abstimmungen vorhanden.</p>
                #endif
            </div>

            <!-- Tab: Wortmeldungen -->
            <div class="tab-pane fade" id="wortmeldungen" role="tabpanel">
                #if(count(transcripts) > 0):
                <div class="d-flex justify-content-end mb-3">
                    <div style="width:320px">
                        <input type="search" class="form-control form-control-sm search-input" data-table="memberTranscriptTable" data-search-attr="true" placeholder="Suche im Text der Wortmeldungen...">
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle sortable-table paged-table" data-page-size="25" id="memberTranscriptTable">
                        <thead class="table-light">
                            <tr>
                                <th class="sortable" data-col="0" style="cursor:pointer">Datum <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                                <th class="sortable" data-col="1" style="cursor:pointer">Geschäft <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                                <th>Text</th>
                                <th class="sortable text-center" data-col="3" style="cursor:pointer">Prop. <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                            </tr>
                        </thead>
                        <tbody>
                            #for(t in transcripts):
                            <tr data-search="#(t.searchText)" style="cursor:pointer" onclick="window.location='/transcripts/#(t.id)?from=parlamentarier'">
                                <td class="text-nowrap">#(t.meetingDate)</td>
                                <td>#if(t.businessID):<code class="text-muted me-1">#(t.businessNumber)</code>#(t.businessTitle)#elseif(t.businessTitle != ""):#(t.businessTitle)#endif</td>
                                <td><small class="text-muted">#(t.textPreview)</small></td>
                                <td class="text-center">#if(t.propositionCount > 0):<span class="badge bg-primary">#(t.propositionCount)</span>#else:<span class="text-muted">-</span>#endif</td>
                            </tr>
                            #endfor
                        </tbody>
                    </table>
                    <nav class="pager" data-table="memberTranscriptTable"></nav>
                </div>
                #else:
                <p class="text-muted">Keine Wortmeldungen vorhanden.</p>
                #endif
            </div>

            <!-- Tab: Kommissionen -->
            <div class="tab-pane fade" id="kommissionen" role="tabpanel">
                #if(count(committees) > 0):
                <table class="table table-sm table-striped">
                    <thead class="table-light">
                        <tr>
                            <th>Kommission</th>
                            <th>Kürzel</th>
                            <th>Rat</th>
                            <th>Funktion</th>
                            <th>Typ</th>
                        </tr>
                    </thead>
                    <tbody>
                        #for(committee in committees):
                        <tr>
                            <td>#(committee.name)</td>
                            <td><code>#(committee.abbreviation)</code></td>
                            <td>#(committee.council)</td>
                            <td>
                                #if(committee.function == "Präsident/in"):
                                <span class="badge bg-primary">#(committee.function)</span>
                                #elseif(committee.function == "Vizepräsident/in"):
                                <span class="badge bg-info text-dark">#(committee.function)</span>
                                #else:
                                <span class="badge bg-secondary">#(committee.function)</span>
                                #endif
                            </td>
                            <td><small class="text-muted">#(committee.type)</small></td>
                        </tr>
                        #endfor
                    </tbody>
                </table>
                #else:
                <p class="text-muted">Keine Kommissionsmitgliedschaften vorhanden.</p>
                #endif
            </div>

            <!-- Tab: Politisches Profil -->
            <div class="tab-pane fade" id="profil" role="tabpanel">
                #if(scores.hasScores):
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <table class="table table-borderless">
                            <tr>
                                <td class="score-label text-end" style="width:180px">Links</td>
                                <td>
                                    <div class="score-bar">
                                        <div class="score-bar-bg">
                                            <div class="score-bar-center"></div>
                                            <div class="score-bar-fill" style="left:#if(scores.leftRight != nil):#if(scores.leftRight < 0):calc(50% + #(scores.leftRight) * 50%)#else:50%#endif#else:50%#endif;width:#if(scores.leftRight != nil):#if(scores.leftRight < 0):calc(#(scores.leftRight) * -50%)#else:calc(#(scores.leftRight) * 50%)#endif#else:0%#endif;background:#if(scores.leftRight != nil):#if(scores.leftRight < 0):#dc3545#else:#0d6efd#endif#else:#6c757d#endif;"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="score-label" style="width:180px">Rechts</td>
                            </tr>
                            <tr>
                                <td class="score-label text-end">Konservativ</td>
                                <td>
                                    <div class="score-bar">
                                        <div class="score-bar-bg">
                                            <div class="score-bar-center"></div>
                                            <div class="score-bar-fill" style="left:#if(scores.conservativeLiberal != nil):#if(scores.conservativeLiberal < 0):calc(50% + #(scores.conservativeLiberal) * 50%)#else:50%#endif#else:50%#endif;width:#if(scores.conservativeLiberal != nil):#if(scores.conservativeLiberal < 0):calc(#(scores.conservativeLiberal) * -50%)#else:calc(#(scores.conservativeLiberal) * 50%)#endif#else:0%#endif;background:#if(scores.conservativeLiberal != nil):#if(scores.conservativeLiberal < 0):#dc3545#else:#0d6efd#endif#else:#6c757d#endif;"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="score-label">Liberal</td>
                            </tr>
                            <tr><td class="score-label text-end">Wenig</td><td><div class="score-bar"><div class="score-bar-bg"><div class="score-bar-center"></div><div class="score-bar-fill" style="left:50%;width:#if(scores.liberalEconomy != nil):calc(#(scores.liberalEconomy) * 50%)#else:0%#endif;background:#198754;"></div></div></div></td><td class="score-label">Liberale Wirtschaft</td></tr>
                            <tr><td class="score-label text-end">Wenig</td><td><div class="score-bar"><div class="score-bar-bg"><div class="score-bar-center"></div><div class="score-bar-fill" style="left:50%;width:#if(scores.innovativeLocation != nil):calc(#(scores.innovativeLocation) * 50%)#else:0%#endif;background:#198754;"></div></div></div></td><td class="score-label">Innovativer Standort</td></tr>
                            <tr><td class="score-label text-end">Wenig</td><td><div class="score-bar"><div class="score-bar-bg"><div class="score-bar-center"></div><div class="score-bar-fill" style="left:50%;width:#if(scores.independentEnergy != nil):calc(#(scores.independentEnergy) * 50%)#else:0%#endif;background:#198754;"></div></div></div></td><td class="score-label">Unabhängige Energie</td></tr>
                            <tr><td class="score-label text-end">Wenig</td><td><div class="score-bar"><div class="score-bar-bg"><div class="score-bar-center"></div><div class="score-bar-fill" style="left:50%;width:#if(scores.strengthResilience != nil):calc(#(scores.strengthResilience) * 50%)#else:0%#endif;background:#198754;"></div></div></div></td><td class="score-label">Stärke / Resilienz</td></tr>
                            <tr><td class="score-label text-end">Wenig</td><td><div class="score-bar"><div class="score-bar-bg"><div class="score-bar-center"></div><div class="score-bar-fill" style="left:50%;width:#if(scores.leanGovernment != nil):calc(#(scores.leanGovernment) * 50%)#else:0%#endif;background:#198754;"></div></div></div></td><td class="score-label">Schlanker Staat</td></tr>
                        </table>
                    </div>
                </div>
                #else:
                <p class="text-muted">Kein politisches Profil vorhanden.</p>
                #endif
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Paging
        function setupPaging(tableId) {
            var table = document.getElementById(tableId);
            if (!table || !table.classList.contains('paged-table')) return null;
            var pageSize = parseInt(table.dataset.pageSize) || 25;
            var pagerNav = document.querySelector('.pager[data-table="' + tableId + '"]');
            var currentPage = 1;
            function getVisibleRows() {
                return Array.from(table.querySelectorAll('tbody tr')).filter(function(r) { return r.dataset.filtered !== 'true'; });
            }
            function render() {
                table.querySelectorAll('tbody tr').forEach(function(r) { if (r.dataset.filtered === 'true') r.style.display = 'none'; });
                var rows = getVisibleRows();
                var totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                if (currentPage > totalPages) currentPage = totalPages;
                rows.forEach(function(r, i) { r.style.display = (i >= (currentPage - 1) * pageSize && i < currentPage * pageSize) ? '' : 'none'; });
                var html = '<ul class="pagination pagination-sm justify-content-center mt-2 mb-0">';
                html += '<li class="page-item' + (currentPage === 1 ? ' disabled' : '') + '"><a class="page-link" href="#" data-p="' + (currentPage - 1) + '">&laquo;</a></li>';
                var sp = Math.max(1, currentPage - 2), ep = Math.min(totalPages, sp + 4);
                if (ep - sp < 4) sp = Math.max(1, ep - 4);
                for (var p = sp; p <= ep; p++) html += '<li class="page-item' + (p === currentPage ? ' active' : '') + '"><a class="page-link" href="#" data-p="' + p + '">' + p + '</a></li>';
                html += '<li class="page-item' + (currentPage === totalPages ? ' disabled' : '') + '"><a class="page-link" href="#" data-p="' + (currentPage + 1) + '">&raquo;</a></li>';
                html += '</ul><div class="text-center text-muted small mt-1">' + rows.length + ' Einträge, Seite ' + currentPage + ' von ' + totalPages + '</div>';
                pagerNav.innerHTML = html;
                pagerNav.querySelectorAll('a[data-p]').forEach(function(a) {
                    a.addEventListener('click', function(e) { e.preventDefault(); var p = parseInt(this.dataset.p); if (p >= 1 && p <= totalPages) { currentPage = p; render(); } });
                });
            }
            return { render: render, resetPage: function() { currentPage = 1; } };
        }
        var pagers = {};
        document.querySelectorAll('.paged-table').forEach(function(t) { var p = setupPaging(t.id); if (p) { pagers[t.id] = p; p.render(); } });

        // Search (Enter)
        document.querySelectorAll('.search-input').forEach(function(input) {
            var tableId = input.dataset.table, tbody = document.getElementById(tableId).querySelector('tbody');
            var useAttr = input.dataset.searchAttr === 'true';
            function doSearch() {
                var term = input.value.toLowerCase();
                tbody.querySelectorAll('tr').forEach(function(row) {
                    var h = useAttr ? (row.dataset.search || '').toLowerCase() : row.textContent.toLowerCase();
                    row.dataset.filtered = (!term || h.includes(term)) ? 'false' : 'true';
                });
                if (pagers[tableId]) { pagers[tableId].resetPage(); pagers[tableId].render(); }
            }
            input.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
            input.addEventListener('search', doSearch);
        });

        // Sort (3 states)
        document.querySelectorAll('.sortable-table').forEach(function(table) {
            var state = { col: -1, dir: 0 }, tbody = table.querySelector('tbody'), orig = Array.from(tbody.querySelectorAll('tr'));
            table.querySelectorAll('th.sortable').forEach(function(th) {
                th.addEventListener('click', function() {
                    var col = parseInt(this.dataset.col);
                    if (state.col === col) { state.dir = (state.dir + 1) % 3; } else { state.col = col; state.dir = 1; }
                    table.querySelectorAll('.arrow-up, .arrow-down').forEach(function(a) { a.classList.remove('active'); });
                    if (state.dir === 0) { orig.forEach(function(r) { tbody.appendChild(r); }); state.col = -1; }
                    else {
                        var asc = state.dir === 1, rows = Array.from(tbody.querySelectorAll('tr'));
                        rows.sort(function(a, b) { var aT = a.cells[col].textContent.trim().toLowerCase(), bT = b.cells[col].textContent.trim().toLowerCase(); return aT < bT ? (asc ? -1 : 1) : aT > bT ? (asc ? 1 : -1) : 0; });
                        rows.forEach(function(r) { tbody.appendChild(r); });
                        this.querySelector(asc ? '.arrow-up' : '.arrow-down').classList.add('active');
                    }
                    if (pagers[table.id]) { pagers[table.id].resetPage(); pagers[table.id].render(); }
                });
            });
        });
    });
    </script>
</body>
</html>
