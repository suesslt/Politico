<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Politico</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark px-3">
        <span class="navbar-brand">Politico</span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Abmelden</a>
    </nav>

    <div class="container-fluid mt-3">
        <ul class="nav nav-tabs" id="mainTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="sessions-tab" data-bs-toggle="tab" data-bs-target="#sessions" type="button" role="tab">Sessions</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="members-tab" data-bs-toggle="tab" data-bs-target="#members" type="button" role="tab">Parlamentarier</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="businesses-tab" data-bs-toggle="tab" data-bs-target="#businesses" type="button" role="tab">Geschäfte</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="transcripts-tab" data-bs-toggle="tab" data-bs-target="#transcripts" type="button" role="tab">Wortmeldungen</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="meetings-tab" data-bs-toggle="tab" data-bs-target="#meetingsTab" type="button" role="tab">Sitzungen</button>
            </li>
        </ul>

        <div class="tab-content mt-3" id="mainTabsContent">

            <!-- Tab 1: Sessions -->
            <div class="tab-pane fade show active" id="sessions" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Parlamentssessions</h5>
                    <form method="POST" action="/sessions/refresh">
                        <button type="submit" class="btn btn-primary btn-sm">Sessions aktualisieren</button>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Session</th>
                                <th>Kürzel</th>
                                <th>Beginn</th>
                                <th>Ende</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            #for(session in sessions):
                            <tr>
                                <td>
                                    <strong>#(session.sessionName)</strong><br>
                                    <small class="text-muted">#(session.title)</small>
                                </td>
                                <td>#(session.abbreviation)</td>
                                <td>#(session.startDate)</td>
                                <td>#(session.endDate)</td>
                                <td>
                                    #if(session.syncStatus == "completed"):
                                    <span class="badge bg-success">Synchronisiert</span>
                                    #elseif(session.syncStatus == "syncing"):
                                    <span class="badge bg-warning text-dark">Syncing...</span>
                                    #elseif(session.syncStatus == "failed"):
                                    <span class="badge bg-danger">Fehlgeschlagen</span>
                                    #else:
                                    <span class="badge bg-secondary">Nicht synchronisiert</span>
                                    #endif
                                </td>
                                <td class="text-end">
                                    <a href="/sessions/#(session.id)" class="btn btn-outline-secondary btn-sm">Details</a>
                                    <form method="POST" action="/sync/#(session.id)" class="d-inline">
                                        <button type="submit" class="btn btn-outline-primary btn-sm">Sync</button>
                                    </form>
                                </td>
                            </tr>
                            #endfor
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tab 2: Parlamentarier -->
            <div class="tab-pane fade" id="members" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Parlamentarier</h5>
                    <div style="width:320px">
                        <input type="text" class="form-control form-control-sm search-input" data-table="memberTable" placeholder="Suche in Parlamentariern...">
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle sortable-table" id="memberTable">
                        <thead class="table-light">
                            <tr>
                                <th class="sortable" data-col="0" style="cursor:pointer">Name <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="1" style="cursor:pointer">Partei <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="2" style="cursor:pointer">Fraktion <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="3" style="cursor:pointer">Kanton <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="4" style="cursor:pointer">Rat <span class="sort-icon"></span></th>
                                <th>Beruf</th>
                            </tr>
                        </thead>
                        <tbody>
                            #for(member in members):
                            <tr>
                                <td><strong>#(member.lastName)</strong>, #(member.firstName)</td>
                                <td><span class="badge" style="background-color:#(member.partyColor);color:#fff">#(member.party)</span></td>
                                <td>#(member.faction)</td>
                                <td>#(member.canton)</td>
                                <td>#(member.council)</td>
                                <td><small class="text-muted">#(member.occupation)</small></td>
                            </tr>
                            #endfor
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tab 3: Geschäfte -->
            <div class="tab-pane fade" id="businesses" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Geschäfte</h5>
                    <div style="width:320px">
                        <input type="text" class="form-control form-control-sm search-input" data-table="businessTable" placeholder="Suche in Geschäften...">
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle sortable-table" id="businessTable">
                        <thead class="table-light">
                            <tr>
                                <th class="sortable" data-col="0" style="cursor:pointer">Nr. <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="1" style="cursor:pointer">Titel <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="2" style="cursor:pointer">Typ <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="3" style="cursor:pointer">Status <span class="sort-icon"></span></th>
                            </tr>
                        </thead>
                        <tbody>
                            #for(business in businesses):
                            <tr>
                                <td><code>#(business.shortNumber)</code></td>
                                <td>#(business.title)</td>
                                <td><span class="badge bg-info text-dark">#(business.typeName)</span></td>
                                <td>#(business.statusText)</td>
                            </tr>
                            #endfor
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tab 4: Wortmeldungen -->
            <div class="tab-pane fade" id="transcripts" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Wortmeldungen</h5>
                    <div style="width:320px">
                        <input type="text" class="form-control form-control-sm search-input" data-table="transcriptTable" placeholder="Suche in Wortmeldungen...">
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle sortable-table" id="transcriptTable">
                        <thead class="table-light">
                            <tr>
                                <th class="sortable" data-col="0" style="cursor:pointer">Datum <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="1" style="cursor:pointer">Redner/in <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="2" style="cursor:pointer">Funktion <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="3" style="cursor:pointer">Fraktion <span class="sort-icon"></span></th>
                                <th class="sortable" data-col="4" style="cursor:pointer">Kanton <span class="sort-icon"></span></th>
                                <th>Text</th>
                            </tr>
                        </thead>
                        <tbody>
                            #for(transcript in transcripts):
                            <tr>
                                <td class="text-nowrap">#(transcript.meetingDate)</td>
                                <td><strong>#(transcript.speakerFullName)</strong></td>
                                <td><small>#(transcript.speakerFunction)</small></td>
                                <td>#(transcript.faction)</td>
                                <td>#(transcript.canton)</td>
                                <td><small class="text-muted">#(transcript.textPreview)</small></td>
                            </tr>
                            #endfor
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tab 5: Sitzungen -->
            <div class="tab-pane fade" id="meetingsTab" role="tabpanel">
                <h5 class="mb-3">Sitzungen</h5>
                #for(sessionGroup in meetingGroups):
                <div class="card mb-3">
                    <div class="card-header bg-dark text-white">
                        <strong>#(sessionGroup.sessionName)</strong>
                        <small class="float-end">#(sessionGroup.sessionDates)</small>
                    </div>
                    <div class="card-body p-0">
                        #for(council in sessionGroup.councils):
                        <div class="border-bottom">
                            <div class="px-3 py-2 bg-light border-bottom">
                                <strong>#(council.councilName)</strong>
                                <span class="badge bg-secondary">#(council.councilAbbreviation)</span>
                            </div>
                            #for(dateGroup in council.dates):
                            <div class="border-bottom">
                                <button class="btn btn-link text-decoration-none w-100 text-start px-3 py-2 d-flex justify-content-between align-items-center collapsed" type="button" data-bs-toggle="collapse" data-bs-target="##(dateGroup.id)">
                                    <span class="fw-semibold text-primary">#(dateGroup.date)</span>
                                    <span class="badge bg-secondary">#(dateGroup.businessCount) Geschäfte</span>
                                </button>
                                <div class="collapse" id="#(dateGroup.id)">
                                    <div class="px-3 pb-2">
                                        #if(count(dateGroup.businesses) > 0):
                                        <ul class="list-group list-group-flush ms-2">
                                            #for(title in dateGroup.businesses):
                                            <li class="list-group-item px-0 py-1 border-0"><small>#(title)</small></li>
                                            #endfor
                                        </ul>
                                        #else:
                                        <small class="text-muted ms-2">Keine Geschäfte verknüpft</small>
                                        #endif
                                    </div>
                                </div>
                            </div>
                            #endfor
                        </div>
                        #endfor
                    </div>
                </div>
                #endfor
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Search: bind each .search-input to its data-table
        document.querySelectorAll('.search-input').forEach(function(input) {
            var tbody = document.getElementById(input.dataset.table).querySelector('tbody');
            input.addEventListener('input', function() {
                var term = this.value.toLowerCase();
                tbody.querySelectorAll('tr').forEach(function(row) {
                    row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
                });
            });
        });

        // Sort: bind each .sortable-table
        document.querySelectorAll('.sortable-table').forEach(function(table) {
            var state = { col: -1, asc: true };
            var tbody = table.querySelector('tbody');
            table.querySelectorAll('th.sortable').forEach(function(th) {
                th.addEventListener('click', function() {
                    var col = parseInt(this.dataset.col);
                    if (state.col === col) { state.asc = !state.asc; } else { state.col = col; state.asc = true; }
                    var rows = Array.from(tbody.querySelectorAll('tr'));
                    rows.sort(function(a, b) {
                        var aT = a.cells[col].textContent.trim().toLowerCase();
                        var bT = b.cells[col].textContent.trim().toLowerCase();
                        return aT < bT ? (state.asc ? -1 : 1) : aT > bT ? (state.asc ? 1 : -1) : 0;
                    });
                    rows.forEach(function(r) { tbody.appendChild(r); });
                    table.querySelectorAll('.sort-icon').forEach(function(i) { i.textContent = ''; });
                    this.querySelector('.sort-icon').textContent = state.asc ? ' ▲' : ' ▼';
                });
            });
        });
    });
    </script>
</body>
</html>
