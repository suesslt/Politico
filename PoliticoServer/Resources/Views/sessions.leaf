<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Politico</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        th.sortable { user-select: none; cursor: pointer; }
        .sort-arrows { display: inline-flex; vertical-align: middle; margin-left: 4px; font-size: 10px; gap: 1px; }
        .sort-arrows .arrow-up, .sort-arrows .arrow-down { color: #ccc; transition: color 0.15s; }
        .sort-arrows .arrow-up.active { color: #212529; }
        .sort-arrows .arrow-down.active { color: #212529; }
        .accordion-chevron { transition: transform 0.2s; display: inline-block; color: #6c757d; transform: rotate(90deg); }
        .collapsed > .accordion-chevron, .collapsed .accordion-chevron { transform: rotate(0deg); }
        .tab-spinner { display: flex; justify-content: center; align-items: center; padding: 3rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark px-3">
        <span class="navbar-brand">Politico</span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Abmelden</a>
    </nav>

    <div class="container-fluid mt-3">
        <ul class="nav nav-tabs" id="mainTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="sessions-tab" data-bs-toggle="tab" data-bs-target="#sessions" type="button" role="tab">Sessions</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="members-tab" data-bs-toggle="tab" data-bs-target="#members" type="button" role="tab" data-api="/api/members">Parlamentarier</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="businesses-tab" data-bs-toggle="tab" data-bs-target="#businesses" type="button" role="tab" data-api="/api/businesses">Geschäfte</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="transcripts-tab" data-bs-toggle="tab" data-bs-target="#transcripts" type="button" role="tab" data-api="/api/transcripts">Wortmeldungen</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="meetings-tab" data-bs-toggle="tab" data-bs-target="#meetingsTab" type="button" role="tab" data-api="/api/meetings">Sitzungen</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="committees-tab" data-bs-toggle="tab" data-bs-target="#committeesTab" type="button" role="tab" data-api="/api/committees">Kommissionen</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="scores-tab" data-bs-toggle="tab" data-bs-target="#scoresTab" type="button" role="tab" data-api="/api/scores">Scores</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="chat-tab" data-bs-toggle="tab" data-bs-target="#chatTab" type="button" role="tab">Chat</button>
            </li>
        </ul>

        <div class="tab-content mt-3" id="mainTabsContent">

            <!-- Tab 1: Sessions (server-rendered) -->
            <div class="tab-pane fade show active" id="sessions" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Parlamentssessions</h5>
                    <form method="POST" action="/sessions/refresh">
                        <button type="submit" class="btn btn-primary btn-sm">Sessions aktualisieren</button>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Session</th>
                                <th>Kürzel</th>
                                <th>Beginn</th>
                                <th>Ende</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            #for(session in sessions):
                            <tr>
                                <td><strong>#(session.sessionName)</strong></td>
                                <td>#(session.abbreviation)</td>
                                <td>#(session.startDate)</td>
                                <td>#(session.endDate)</td>
                                <td>
                                    #if(session.syncStatus == "completed"):
                                    <span class="badge bg-success">Synchronisiert</span>
                                    #elseif(session.syncStatus == "syncing"):
                                    <span class="badge bg-warning text-dark">Syncing...</span>
                                    #elseif(session.syncStatus == "failed"):
                                    <span class="badge bg-danger">Fehlgeschlagen</span>
                                    #else:
                                    <span class="badge bg-secondary">Nicht synchronisiert</span>
                                    #endif
                                </td>
                                <td class="text-end">
                                    <a href="/sessions/#(session.id)" class="btn btn-outline-secondary btn-sm">Details</a>
                                    <form method="POST" action="/sync/#(session.id)" class="d-inline">
                                        <button type="submit" class="btn btn-outline-primary btn-sm">Sync</button>
                                    </form>
                                </td>
                            </tr>
                            #endfor
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tab 2: Parlamentarier (lazy) -->
            <div class="tab-pane fade" id="members" role="tabpanel">
                <div class="tab-spinner"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Laden...</span></div></div>
            </div>

            <!-- Tab 3: Geschäfte (lazy) -->
            <div class="tab-pane fade" id="businesses" role="tabpanel">
                <div class="tab-spinner"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Laden...</span></div></div>
            </div>

            <!-- Tab 4: Wortmeldungen (lazy) -->
            <div class="tab-pane fade" id="transcripts" role="tabpanel">
                <div class="tab-spinner"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Laden...</span></div></div>
            </div>

            <!-- Tab 5: Sitzungen (lazy) -->
            <div class="tab-pane fade" id="meetingsTab" role="tabpanel">
                <div class="tab-spinner"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Laden...</span></div></div>
            </div>

            <!-- Tab 6: Kommissionen (lazy) -->
            <div class="tab-pane fade" id="committeesTab" role="tabpanel">
                <div class="tab-spinner"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Laden...</span></div></div>
            </div>

            <!-- Tab 7: Scores (lazy) -->
            <div class="tab-pane fade" id="scoresTab" role="tabpanel">
                <div class="tab-spinner"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Laden...</span></div></div>
            </div>

            <!-- Tab 8: Chat -->
            <div class="tab-pane fade" id="chatTab" role="tabpanel">
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Chat mit Parlamentsdaten</h5>
                            <div class="d-flex align-items-center gap-2">
                                <span id="embStatus" class="text-muted small"></span>
                                <button id="btnStartEmb" class="btn btn-outline-secondary btn-sm" onclick="fetch('/embeddings/generate',{method:'POST'}).then(function(){pollEmbeddingStatus()});showEmbButtons(true)">Embeddings generieren</button>
                                <button id="btnStopEmb" class="btn btn-outline-danger btn-sm" onclick="fetch('/embeddings/stop',{method:'POST'});this.disabled=true;this.textContent='Stoppe...'" style="display:none">Stop</button>
                            </div>
                        </div>
                        <div id="chatMessages" class="border rounded p-3 mb-3" style="height:500px;overflow-y:auto;background:#f8f9fa">
                            <div class="text-center text-muted py-5">
                                <p>Stelle Fragen zu den Wortmeldungen im Parlament.</p>
                                <p class="small">z.B. &laquo;Welche Positionen gibt es zur Energiewende?&raquo;</p>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <input type="text" id="chatInput" class="form-control" placeholder="Frage eingeben..." autocomplete="off">
                            <button type="button" id="chatSendBtn" class="btn btn-primary px-4" onclick="sendChatMessage()">Senden</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/chat.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {

        var loadedTabs = {};
        var pagers = {};

        // ---- Escape HTML to prevent XSS ----
        function esc(s) {
            if (!s) return '';
            var d = document.createElement('div');
            d.textContent = s;
            return d.innerHTML;
        }

        // ---- Tab renderers ----
        var renderers = {
            members: function(data, container) {
                var html = '<div class="d-flex justify-content-between align-items-center mb-3">'
                    + '<h5 class="mb-0">Parlamentarier</h5>'
                    + '<div style="width:320px"><input type="search" class="form-control form-control-sm live-search-input" data-table="memberTable" placeholder="Suche in Parlamentariern..."></div></div>'
                    + '<div class="table-responsive"><table class="table table-striped table-hover align-middle sortable-table" id="memberTable"><thead class="table-light"><tr>'
                    + '<th class="sortable" data-col="0">Name <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="1">Partei <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="2">Fraktion <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="3">Kanton <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="4">Rat <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th>Beruf</th>'
                    + '<th class="sortable text-center" data-col="6">Status <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '</tr></thead><tbody>';
                data.forEach(function(m) {
                    var rowStyle = m.active ? '' : ' style="opacity:0.5"';
                    var statusBadge = m.active ? '<span class="badge bg-success">Aktiv</span>' : '<span class="badge bg-secondary">Ehemalig</span>';
                    html += '<tr' + rowStyle + '><td><a href="/members/' + m.id + '?from=parlamentarier" class="text-decoration-none text-dark"><strong>' + esc(m.lastName) + '</strong>, ' + esc(m.firstName) + '</a></td>'
                        + '<td><span class="badge" style="background-color:' + esc(m.partyColor) + ';color:#fff">' + esc(m.party) + '</span></td>'
                        + '<td>' + esc(m.faction) + '</td><td>' + esc(m.canton) + '</td><td>' + esc(m.council) + '</td>'
                        + '<td><small class="text-muted">' + esc(m.occupation) + '</small></td>'
                        + '<td class="text-center">' + statusBadge + '</td></tr>';
                });
                html += '</tbody></table></div>';
                container.innerHTML = html;
                initSortable(container);
                initLiveSearch(container);
            },

            businesses: function(data, container) {
                var html = '<div class="d-flex justify-content-between align-items-center mb-3">'
                    + '<h5 class="mb-0">Geschäfte</h5>'
                    + '<div style="width:320px"><input type="search" class="form-control form-control-sm search-input" data-table="businessTable" placeholder="Suche in Geschäften..."></div></div>'
                    + '<div class="table-responsive"><table class="table table-striped table-hover align-middle sortable-table paged-table" data-page-size="25" id="businessTable"><thead class="table-light"><tr>'
                    + '<th class="sortable" data-col="0">Nr. <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="1">Titel <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="2">Typ <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="3">Eingereicht von <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="4">Status <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '</tr></thead><tbody>';
                data.forEach(function(b) {
                    var submitter = '';
                    if (b.submittedByID) {
                        submitter = '<a href="/members/' + b.submittedByID + '?from=geschaefte" class="text-decoration-none"><span class="badge" style="background-color:' + esc(b.submittedByPartyColor) + ';color:#fff">&#9679;</span> ' + esc(b.submittedByName) + '</a>';
                    } else {
                        submitter = esc(b.submittedBy);
                    }
                    html += '<tr><td><code>' + esc(b.shortNumber) + '</code></td>'
                        + '<td><a href="/businesses/' + b.id + '?from=geschaefte" class="text-decoration-none text-dark">' + esc(b.title) + '</a></td>'
                        + '<td><span class="badge bg-info text-dark">' + esc(b.typeName) + '</span></td>'
                        + '<td>' + submitter + '</td>'
                        + '<td>' + esc(b.statusText) + '</td></tr>';
                });
                html += '</tbody></table><nav class="pager" data-table="businessTable"></nav></div>';
                container.innerHTML = html;
                initSortable(container);
                initSearchInput(container);
                var p = setupPaging('businessTable');
                if (p) { pagers['businessTable'] = p; p.render(); }
            },

            transcripts: function(data, container) {
                var html = '<div class="d-flex justify-content-between align-items-center mb-3">'
                    + '<h5 class="mb-0">Wortmeldungen</h5>'
                    + '<div class="d-flex align-items-center gap-2">'
                    + '<span id="propStatus" class="text-muted small"></span>'
                    + '<button id="btnStartProps" class="btn btn-outline-primary btn-sm" onclick="fetch(\'/propositions/extract\',{method:\'POST\'}).then(function(){pollPropositionStatus()});showPropButtons(true)">Propositions extrahieren</button>'
                    + '<button id="btnStopProps" class="btn btn-outline-danger btn-sm" onclick="fetch(\'/propositions/stop\',{method:\'POST\'});this.disabled=true;this.textContent=\'Stoppe...\'" style="display:none">Stop</button>'
                    + '<div style="width:320px"><input type="search" class="form-control form-control-sm search-input" data-table="transcriptTable" data-search-attr="true" placeholder="Suche im Text der Wortmeldungen..."></div>'
                    + '</div></div>'
                    + '<div class="table-responsive"><table class="table table-striped table-hover align-middle sortable-table paged-table" data-page-size="25" id="transcriptTable"><thead class="table-light"><tr>'
                    + '<th class="sortable" data-col="0">Datum <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="1">Redner/in <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="2">Partei <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable" data-col="3">Geschäft <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '<th class="sortable text-center" data-col="4">Prop. <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                    + '</tr></thead><tbody>';
                data.forEach(function(t) {
                    var speaker = t.speakerID
                        ? '<a href="/members/' + t.speakerID + '?from=wortmeldungen" class="text-decoration-none text-dark"><strong>' + esc(t.speakerFullName) + '</strong></a>'
                        : '<strong>' + esc(t.speakerFullName) + '</strong>';
                    var biz = '';
                    if (t.businessShortNumber) biz += '<code class="text-muted me-1">' + esc(t.businessShortNumber) + '</code>';
                    biz += '<small>' + esc(t.businessTitle) + '</small>';
                    var propBadge = t.propositionCount > 0 ? '<span class="badge bg-primary">' + t.propositionCount + '</span>' : '<span class="text-muted">-</span>';
                    html += '<tr data-search="' + esc(t.searchText) + '" style="cursor:pointer" onclick="window.location=\'/transcripts/' + t.id + '?from=wortmeldungen\'">'
                        + '<td class="text-nowrap">' + esc(t.meetingDate) + '</td>'
                        + '<td>' + speaker + '</td>'
                        + '<td><span class="badge" style="background-color:' + esc(t.partyColor) + ';color:#fff">' + esc(t.partyAbbreviation) + '</span></td>'
                        + '<td>' + biz + '</td>'
                        + '<td class="text-center">' + propBadge + '</td></tr>';
                });
                html += '</tbody></table><nav class="pager" data-table="transcriptTable"></nav></div>';
                container.innerHTML = html;
                initSortable(container);
                initSearchInput(container);
                var p = setupPaging('transcriptTable');
                if (p) { pagers['transcriptTable'] = p; p.render(); }
                // Load current proposition status (chat.js may not be loaded yet)
                if (typeof updatePropositionStatus === 'function') updatePropositionStatus();
            },

            meetingsTab: function(data, container) {
                var html = '<h5 class="mb-3">Sitzungen</h5><div class="accordion" id="meetingsAccordion">';
                data.forEach(function(sg) {
                    html += '<div class="accordion-item"><h2 class="accordion-header">'
                        + '<button class="btn w-100 text-start d-flex justify-content-between align-items-center px-3 py-2 bg-dark text-white collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#' + sg.id + '">'
                        + '<span><strong>' + esc(sg.sessionName) + '</strong> <small class="ms-2 opacity-75">' + esc(sg.sessionDates) + '</small></span>'
                        + '<span class="accordion-chevron">&#9654;</span></button></h2>'
                        + '<div id="' + sg.id + '" class="collapse" data-bs-parent="#meetingsAccordion"><div class="accordion-body p-0">';
                    (sg.councils || []).forEach(function(council) {
                        html += '<div class="border-bottom">'
                            + '<button class="btn w-100 text-start d-flex justify-content-between align-items-center px-3 py-2 bg-light collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#' + council.id + '">'
                            + '<span><strong>' + esc(council.councilName) + '</strong> <span class="badge bg-secondary ms-1">' + esc(council.councilAbbreviation) + '</span></span>'
                            + '<span class="accordion-chevron">&#9654;</span></button>'
                            + '<div id="' + council.id + '" class="collapse">';
                        (council.dates || []).forEach(function(dg) {
                            html += '<div class="border-top">'
                                + '<button class="btn btn-link text-decoration-none w-100 text-start d-flex justify-content-between align-items-center px-4 py-2 collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#' + dg.id + '">'
                                + '<span class="fw-semibold text-primary">' + esc(dg.date) + '</span>'
                                + '<span><span class="badge bg-secondary me-2">' + dg.businessCount + ' Geschäfte</span><span class="accordion-chevron">&#9654;</span></span></button>'
                                + '<div class="collapse" id="' + dg.id + '"><div class="px-4 pb-2">';
                            if (dg.businesses && dg.businesses.length > 0) {
                                html += '<table class="table table-sm table-borderless mb-0 ms-2">';
                                dg.businesses.forEach(function(biz) {
                                    html += '<tr style="cursor:pointer" onclick="window.location=\'/businesses/' + biz.id + '?from=sitzungen\'">'
                                        + '<td style="width:100px"><code class="text-muted">' + esc(biz.shortNumber) + '</code></td>'
                                        + '<td><small>' + esc(biz.title) + '</small></td>'
                                        + '<td style="width:150px">' + (biz.typeName ? '<span class="badge bg-info text-dark" style="font-weight:normal">' + esc(biz.typeName) + '</span>' : '') + '</td></tr>';
                                });
                                html += '</table>';
                            } else {
                                html += '<small class="text-muted ms-2">Keine Geschäfte verknüpft</small>';
                            }
                            html += '</div></div></div>';
                        });
                        html += '</div></div>';
                    });
                    html += '</div></div></div>';
                });
                html += '</div>';
                container.innerHTML = html;
            },

            committeesTab: function(data, container) {
                var html = '<h5 class="mb-3">Kommissionen</h5><div class="accordion" id="committeesAccordion">';
                data.forEach(function(c) {
                    if (c.memberCount <= 0) return;
                    var abbr = c.abbreviation ? '<code class="ms-2">' + esc(c.abbreviation) + '</code>' : '';
                    var council = c.council ? '<span class="badge bg-secondary ms-1">' + esc(c.council) + '</span>' : '';
                    html += '<div class="accordion-item"><h2 class="accordion-header">'
                        + '<button class="btn w-100 text-start d-flex justify-content-between align-items-center px-3 py-2 border-bottom collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#' + c.id + '">'
                        + '<span><strong>' + esc(c.name) + '</strong>' + abbr + council + '<small class="text-muted ms-2">' + esc(c.committeeType) + '</small></span>'
                        + '<span><span class="badge bg-primary me-2">' + c.memberCount + '</span><span class="accordion-chevron">&#9654;</span></span></button></h2>'
                        + '<div id="' + c.id + '" class="collapse"><div class="p-0">'
                        + '<table class="table table-sm table-striped table-hover mb-0"><thead class="table-light"><tr><th>Name</th><th>Partei</th><th>Kanton</th><th>Funktion</th></tr></thead><tbody>';
                    (c.members || []).forEach(function(m) {
                        var fnClass = m.function === 'Präsident/in' ? 'bg-primary' : m.function === 'Vizepräsident/in' ? 'bg-info text-dark' : 'bg-secondary';
                        html += '<tr><td><a href="/members/' + m.id + '?from=kommissionen" class="text-decoration-none text-dark"><strong>' + esc(m.lastName) + '</strong>, ' + esc(m.firstName) + '</a></td>'
                            + '<td><span class="badge" style="background-color:' + esc(m.partyColor) + ';color:#fff">' + esc(m.party) + '</span></td>'
                            + '<td>' + esc(m.canton) + '</td>'
                            + '<td><span class="badge ' + fnClass + '">' + esc(m.function) + '</span></td></tr>';
                    });
                    html += '</tbody></table></div></div></div>';
                });
                html += '</div>';
                container.innerHTML = html;
            },

            scoresTab: function(data, container) {
                var html = '<h5 class="mb-3">Scores</h5>';
                (data.rankings || []).forEach(function(ranking) {
                    html += '<div class="card mb-4"><div class="card-header bg-dark text-white d-flex justify-content-between align-items-center" role="button" data-bs-toggle="collapse" data-bs-target="#' + ranking.id + '">'
                        + '<div><strong>' + esc(ranking.title) + '</strong><br><small class="opacity-75">' + esc(ranking.description) + '</small></div>'
                        + '<span class="accordion-chevron">&#9654;</span></div>'
                        + '<div class="collapse show" id="' + ranking.id + '"><div class="card-body p-0">'
                        + '<table class="table table-striped table-hover align-middle mb-0 sortable-table" id="score-' + ranking.id + '"><thead class="table-light"><tr>'
                        + '<th style="width:50px" class="sortable" data-col="0">Rang <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                        + '<th class="sortable" data-col="1">Name <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                        + '<th class="sortable" data-col="2">Partei <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                        + '<th class="sortable" data-col="3">Rat <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                        + '<th class="sortable text-end" data-col="4">Anzahl <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>'
                        + '<th>Detail</th></tr></thead><tbody>';
                    ranking.entries.forEach(function(e, idx) {
                        html += '<tr>'
                            + '<td class="text-muted">' + (idx + 1) + '</td>'
                            + '<td><a href="/members/' + e.memberID + '?from=scores" class="text-decoration-none text-dark"><strong>' + esc(e.lastName) + '</strong>, ' + esc(e.firstName) + '</a></td>'
                            + '<td><span class="badge" style="background-color:' + esc(e.partyColor) + ';color:#fff">' + esc(e.party) + '</span></td>'
                            + '<td>' + esc(e.council) + '</td>'
                            + '<td class="text-end"><strong>' + e.value + '</strong></td>'
                            + '<td><small class="text-muted">' + esc(e.detail) + '</small></td></tr>';
                    });
                    html += '</tbody></table></div></div></div>';
                });
                container.innerHTML = html;
                initSortable(container);
            }
        };

        // ---- Lazy-load on tab show ----
        document.querySelectorAll('[data-bs-toggle="tab"][data-api]').forEach(function(tabBtn) {
            tabBtn.addEventListener('shown.bs.tab', function() {
                var target = tabBtn.dataset.bsTarget.replace('#', '');
                if (loadedTabs[target]) return;
                loadedTabs[target] = true;
                var container = document.getElementById(target);
                fetch(tabBtn.dataset.api)
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (renderers[target]) renderers[target](data, container);
                    })
                    .catch(function(err) {
                        container.innerHTML = '<div class="alert alert-danger m-3">Fehler beim Laden: ' + esc(err.message) + '</div>';
                    });
            });
        });

        // ---- Restore active tab ----
        var activeTab = sessionStorage.getItem('activeTab') || window.location.hash;
        if (activeTab) {
            sessionStorage.removeItem('activeTab');
            var tabBtn = document.querySelector('[data-bs-target="' + activeTab + '"]');
            if (tabBtn) { new bootstrap.Tab(tabBtn).show(); }
        }

        // ---- Paging ----
        function setupPaging(tableId) {
            var table = document.getElementById(tableId);
            if (!table || !table.classList.contains('paged-table')) return null;
            var pageSize = parseInt(table.dataset.pageSize) || 25;
            var pagerNav = document.querySelector('.pager[data-table="' + tableId + '"]');
            var currentPage = 1;

            function getVisibleRows() {
                return Array.from(table.querySelectorAll('tbody tr')).filter(function(r) {
                    return r.dataset.filtered !== 'true';
                });
            }

            function render() {
                table.querySelectorAll('tbody tr').forEach(function(r) {
                    if (r.dataset.filtered === 'true') r.style.display = 'none';
                });
                var rows = getVisibleRows();
                var totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                if (currentPage > totalPages) currentPage = totalPages;

                rows.forEach(function(r, i) {
                    r.style.display = (i >= (currentPage - 1) * pageSize && i < currentPage * pageSize) ? '' : 'none';
                });

                var html = '<ul class="pagination pagination-sm justify-content-center mt-2 mb-0">';
                html += '<li class="page-item' + (currentPage === 1 ? ' disabled' : '') + '"><a class="page-link" href="#" data-p="' + (currentPage - 1) + '">&laquo;</a></li>';
                var startPage = Math.max(1, currentPage - 2);
                var endPage = Math.min(totalPages, startPage + 4);
                if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
                for (var p = startPage; p <= endPage; p++) {
                    html += '<li class="page-item' + (p === currentPage ? ' active' : '') + '"><a class="page-link" href="#" data-p="' + p + '">' + p + '</a></li>';
                }
                html += '<li class="page-item' + (currentPage === totalPages ? ' disabled' : '') + '"><a class="page-link" href="#" data-p="' + (currentPage + 1) + '">&raquo;</a></li>';
                html += '</ul>';
                html += '<div class="text-center text-muted small mt-1">' + rows.length + ' Einträge, Seite ' + currentPage + ' von ' + totalPages + '</div>';
                pagerNav.innerHTML = html;

                pagerNav.querySelectorAll('a[data-p]').forEach(function(a) {
                    a.addEventListener('click', function(e) {
                        e.preventDefault();
                        var pg = parseInt(this.dataset.p);
                        if (pg >= 1 && pg <= totalPages) { currentPage = pg; render(); }
                    });
                });
            }

            return { render: render, resetPage: function() { currentPage = 1; } };
        }

        // ---- Live search ----
        function initLiveSearch(root) {
            (root || document).querySelectorAll('.live-search-input').forEach(function(input) {
                var tbody = document.getElementById(input.dataset.table).querySelector('tbody');
                input.addEventListener('input', function() {
                    var term = this.value.toLowerCase();
                    tbody.querySelectorAll('tr').forEach(function(row) {
                        row.style.display = !term || row.textContent.toLowerCase().includes(term) ? '' : 'none';
                    });
                });
            });
        }

        // ---- Search (Enter key) ----
        function initSearchInput(root) {
            (root || document).querySelectorAll('.search-input').forEach(function(input) {
                var tableId = input.dataset.table;
                var useSearchAttr = input.dataset.searchAttr === 'true';

                function doSearch() {
                    var tbody = document.getElementById(tableId).querySelector('tbody');
                    var term = input.value.toLowerCase();
                    tbody.querySelectorAll('tr').forEach(function(row) {
                        var haystack = useSearchAttr ? (row.dataset.search || '').toLowerCase() : row.textContent.toLowerCase();
                        row.dataset.filtered = (!term || haystack.includes(term)) ? 'false' : 'true';
                    });
                    if (pagers[tableId]) { pagers[tableId].resetPage(); pagers[tableId].render(); }
                }

                input.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
                input.addEventListener('search', doSearch);
            });
        }

        // ---- Sortable tables ----
        function initSortable(root) {
            (root || document).querySelectorAll('.sortable-table').forEach(function(table) {
                var state = { col: -1, dir: 0 };
                var tbody = table.querySelector('tbody');
                var originalRows = Array.from(tbody.querySelectorAll('tr'));

                function resetArrows(tbl) {
                    tbl.querySelectorAll('.arrow-up, .arrow-down').forEach(function(a) { a.classList.remove('active'); });
                }

                table.querySelectorAll('th.sortable').forEach(function(th) {
                    th.addEventListener('click', function() {
                        var col = parseInt(this.dataset.col);
                        if (state.col === col) { state.dir = (state.dir + 1) % 3; }
                        else { state.col = col; state.dir = 1; }
                        resetArrows(table);
                        if (state.dir === 0) {
                            originalRows.forEach(function(r) { tbody.appendChild(r); });
                            state.col = -1;
                        } else {
                            var asc = state.dir === 1;
                            var rows = Array.from(tbody.querySelectorAll('tr'));
                            rows.sort(function(a, b) {
                                var aT = a.cells[col].textContent.trim().toLowerCase();
                                var bT = b.cells[col].textContent.trim().toLowerCase();
                                return aT < bT ? (asc ? -1 : 1) : aT > bT ? (asc ? 1 : -1) : 0;
                            });
                            rows.forEach(function(r) { tbody.appendChild(r); });
                            this.querySelector(asc ? '.arrow-up' : '.arrow-down').classList.add('active');
                        }
                        if (pagers[table.id]) { pagers[table.id].resetPage(); pagers[table.id].render(); }
                    });
                });
            });
        }

    });

    // Proposition functions are in chat.js
    </script>
    <script>
    document.getElementById('chatInput').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); sendChatMessage(); }
    });
    document.getElementById('chat-tab').addEventListener('shown.bs.tab', function() {
        updateEmbeddingStatus();
    });
    </script>
</body>
</html>
