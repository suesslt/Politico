<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Politico - Sync Status</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f7; color: #1d1d1f; }
        .navbar { background: white; padding: 16px 24px; border-bottom: 1px solid #d2d2d7; display: flex; justify-content: space-between; align-items: center; }
        .navbar h1 { font-size: 20px; }
        .navbar a { color: #0071e3; text-decoration: none; font-size: 14px; }
        .container { max-width: 960px; margin: 24px auto; padding: 0 16px; }
        h2 { font-size: 22px; margin-bottom: 16px; }
        .info { color: #86868b; font-size: 14px; margin-bottom: 16px; }
        table { width: 100%; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); border-collapse: collapse; }
        th { background: #f5f5f7; text-align: left; padding: 12px 16px; font-size: 14px; font-weight: 600; border-bottom: 1px solid #d2d2d7; }
        td { padding: 12px 16px; font-size: 14px; border-bottom: 1px solid #f0f0f0; }
        .status-completed { color: #34c759; font-weight: 500; }
        .status-syncing { color: #ff9500; font-weight: 500; }
        .status-failed { color: #ff3b30; font-weight: 500; }
        .status-pending { color: #86868b; }
        .back-link { display: inline-block; margin-bottom: 16px; color: #0071e3; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>
    <nav class="navbar">
        <h1>Politico</h1>
        <a href="/logout">Abmelden</a>
    </nav>
    <div class="container">
        <a href="/sessions" class="back-link">&larr; Zurück zu Sessions</a>
        <h2>Sync Status - Session #(sessionID)</h2>
        <p class="info" id="refreshInfo">Diese Seite aktualisiert sich automatisch alle 5 Sekunden.</p>
        <script>
        if (!document.querySelector('.status-syncing')) {
            document.getElementById('refreshInfo').textContent = 'Synchronisation abgeschlossen oder fehlgeschlagen.';
        }
        </script>
        <table>
            <thead>
                <tr>
                    <th>Entity</th>
                    <th>Status</th>
                    <th>Einträge</th>
                    <th>Letzte Synchronisation</th>
                    <th>Fehler</th>
                </tr>
            </thead>
            <tbody>
                #for(status in statuses):
                <tr>
                    <td>#(status.entityName)</td>
                    <td>
                        #if(status.status == "completed"):
                        <span class="status-completed">Abgeschlossen</span>
                        #elseif(status.status == "syncing"):
                        <span class="status-syncing">Synchronisiert...</span>
                        #elseif(status.status == "failed"):
                        <span class="status-failed">Fehlgeschlagen</span>
                        #else:
                        <span class="status-pending">#(status.status)</span>
                        #endif
                    </td>
                    <td>#(status.itemsSynced)</td>
                    <td>#(status.lastSyncAt)</td>
                    <td>#(status.errorMessage)</td>
                </tr>
                #endfor
            </tbody>
        </table>
    </div>
    <script>
    // Only auto-refresh if sync is still running
    var hasRunning = document.querySelector('.status-syncing') !== null;
    if (hasRunning) {
        setTimeout(function() { location.reload(); }, 5000);
    }
    </script>
</body>
</html>
