<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Politico - #(number) #(title)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        th.sortable { user-select: none; }
        .sort-arrows { display: inline-flex; vertical-align: middle; margin-left: 4px; font-size: 10px; gap: 1px; }
        .sort-arrows .arrow-up, .sort-arrows .arrow-down { color: #ccc; transition: color 0.15s; }
        .sort-arrows .arrow-up.active { color: #212529; }
        .sort-arrows .arrow-down.active { color: #212529; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark px-3">
        <span class="navbar-brand">Politico</span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Abmelden</a>
    </nav>

    <div class="container-fluid mt-3">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/sessions" id="backLink">Übersicht</a></li>
                <li class="breadcrumb-item active">#(number) #(title)</li>
            </ol>
        </nav>
        <script>
        (function() {
            var from = '#(backURL)';
            var memberID = '#(backMemberID)';
            var link = document.getElementById('backLink');
            if (from === 'member' && memberID) {
                link.href = '/members/' + memberID;
                link.textContent = 'Parlamentarier';
            } else {
                var tabMap = { 'geschaefte': '#businesses' };
                if (tabMap[from]) {
                    link.href = '/sessions' + tabMap[from];
                    link.textContent = 'Geschäfte';
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        sessionStorage.setItem('activeTab', tabMap[from]);
                        window.location.href = '/sessions';
                    });
                }
            }
        })();
        </script>

        <!-- Header -->
        <div class="mb-3">
            <h4 class="mb-1">#(title)</h4>
            <code class="me-2">#(number)</code>
            #if(businessType != ""):<span class="badge bg-info text-dark">#(businessType)</span>#endif
            <span class="badge bg-secondary ms-1">#(status)</span>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#stammdaten" type="button">Stammdaten</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#wortmeldungen" type="button">Wortmeldungen <span class="badge bg-secondary">#(count(transcripts))</span></button></li>
        </ul>

        <div class="tab-content mt-3">

            <!-- Tab: Stammdaten -->
            <div class="tab-pane fade show active" id="stammdaten" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr><th style="width:200px">Nummer</th><td><code>#(number)</code></td></tr>
                            <tr><th>Typ</th><td>#(businessType) #if(businessTypeAbbreviation != ""):(<code>#(businessTypeAbbreviation)</code>)#endif</td></tr>
                            <tr><th>Status</th><td>#(status)</td></tr>
                            <tr><th>Status Datum</th><td>#(statusDate)</td></tr>
                            <tr><th>Einreichdatum</th><td>#(submissionDate)</td></tr>
                            <tr><th>Eingereicht von</th><td>#if(submittedByID):<a href="/members/#(submittedByID)" class="text-decoration-none"><span class="badge" style="background-color:#(submittedByPartyColor);color:#fff">&#9679;</span> #(submittedByName)</a>#else:#(submittedBy)#endif</td></tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-sm">
                            <tr><th style="width:200px">Session</th><td>#(sessionName)</td></tr>
                            <tr><th>Einreichungsrat</th><td>#(submissionCouncil)</td></tr>
                            <tr><th>Zuständiges Departement</th><td>#(responsibleDepartment) #if(responsibleDepartmentAbbreviation != ""):(<code>#(responsibleDepartmentAbbreviation)</code>)#endif</td></tr>
                            <tr><th>Tags</th><td><small class="text-muted">#(tagNames)</small></td></tr>
                        </table>
                    </div>
                </div>
                #if(description != ""):
                <h6>Beschreibung</h6>
                <p class="text-muted small">#(description)</p>
                #endif

                #if(submittedText != ""):
                <div class="card mb-3">
                    <div class="card-header"><strong>Eingereichter Text</strong></div>
                    <div class="card-body small">#unsafeHTML(submittedText)</div>
                </div>
                #endif

                #if(reasonText != ""):
                <div class="card mb-3">
                    <div class="card-header"><strong>Begründung</strong></div>
                    <div class="card-body small">#unsafeHTML(reasonText)</div>
                </div>
                #endif

                #if(federalCouncilProposal != ""):
                <div class="card mb-3">
                    <div class="card-header"><strong>Antrag des Bundesrates</strong></div>
                    <div class="card-body small">#unsafeHTML(federalCouncilProposal)</div>
                </div>
                #endif

                #if(federalCouncilResponse != ""):
                <div class="card mb-3">
                    <div class="card-header"><strong>Stellungnahme des Bundesrates</strong></div>
                    <div class="card-body small">#unsafeHTML(federalCouncilResponse)</div>
                </div>
                #endif
            </div>

            <!-- Tab: Wortmeldungen -->
            <div class="tab-pane fade" id="wortmeldungen" role="tabpanel">
                #if(count(transcripts) > 0):
                <div class="d-flex justify-content-end mb-3">
                    <div style="width:320px">
                        <input type="search" class="form-control form-control-sm search-input" data-table="bizTranscriptTable" data-search-attr="true" placeholder="Suche im Text der Wortmeldungen...">
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle sortable-table paged-table" data-page-size="25" id="bizTranscriptTable">
                        <thead class="table-light">
                            <tr>
                                <th class="sortable" data-col="0" style="cursor:pointer">Datum <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                                <th class="sortable" data-col="1" style="cursor:pointer">Redner/in <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                                <th class="sortable" data-col="2" style="cursor:pointer">Funktion <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                                <th class="sortable" data-col="3" style="cursor:pointer">Partei <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                                <th class="sortable text-center" data-col="4" style="cursor:pointer">Prop. <span class="sort-arrows"><span class="arrow-up">&#9650;</span><span class="arrow-down">&#9660;</span></span></th>
                            </tr>
                        </thead>
                        <tbody>
                            #for(t in transcripts):
                            <tr data-search="#(t.searchText)" style="cursor:pointer" onclick="window.location='/transcripts/#(t.id)?from=geschaefte'">
                                <td class="text-nowrap">#(t.meetingDate)</td>
                                <td><strong>#(t.speakerFullName)</strong></td>
                                <td><small>#(t.speakerFunction)</small></td>
                                <td><span class="badge" style="background-color:#(t.partyColor);color:#fff">#(t.partyAbbreviation)</span></td>
                                <td class="text-center">#if(t.propositionCount > 0):<span class="badge bg-primary">#(t.propositionCount)</span>#else:<span class="text-muted">-</span>#endif</td>
                            </tr>
                            #endfor
                        </tbody>
                    </table>
                    <nav class="pager" data-table="bizTranscriptTable"></nav>
                </div>
                #else:
                <p class="text-muted">Keine Wortmeldungen zu diesem Geschäft.</p>
                #endif
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {

        // Paging
        function setupPaging(tableId) {
            var table = document.getElementById(tableId);
            if (!table || !table.classList.contains('paged-table')) return null;
            var pageSize = parseInt(table.dataset.pageSize) || 25;
            var pagerNav = document.querySelector('.pager[data-table="' + tableId + '"]');
            var currentPage = 1;

            function getVisibleRows() {
                return Array.from(table.querySelectorAll('tbody tr')).filter(function(r) {
                    return r.dataset.filtered !== 'true';
                });
            }

            function render() {
                table.querySelectorAll('tbody tr').forEach(function(r) {
                    if (r.dataset.filtered === 'true') r.style.display = 'none';
                });
                var rows = getVisibleRows();
                var totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                if (currentPage > totalPages) currentPage = totalPages;
                rows.forEach(function(r, i) {
                    r.style.display = (i >= (currentPage - 1) * pageSize && i < currentPage * pageSize) ? '' : 'none';
                });
                var html = '<ul class="pagination pagination-sm justify-content-center mt-2 mb-0">';
                html += '<li class="page-item' + (currentPage === 1 ? ' disabled' : '') + '"><a class="page-link" href="#" data-p="' + (currentPage - 1) + '">&laquo;</a></li>';
                var startPage = Math.max(1, currentPage - 2), endPage = Math.min(totalPages, startPage + 4);
                if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
                for (var p = startPage; p <= endPage; p++) {
                    html += '<li class="page-item' + (p === currentPage ? ' active' : '') + '"><a class="page-link" href="#" data-p="' + p + '">' + p + '</a></li>';
                }
                html += '<li class="page-item' + (currentPage === totalPages ? ' disabled' : '') + '"><a class="page-link" href="#" data-p="' + (currentPage + 1) + '">&raquo;</a></li>';
                html += '</ul><div class="text-center text-muted small mt-1">' + rows.length + ' Einträge, Seite ' + currentPage + ' von ' + totalPages + '</div>';
                pagerNav.innerHTML = html;
                pagerNav.querySelectorAll('a[data-p]').forEach(function(a) {
                    a.addEventListener('click', function(e) {
                        e.preventDefault();
                        var p = parseInt(this.dataset.p);
                        if (p >= 1 && p <= totalPages) { currentPage = p; render(); }
                    });
                });
            }
            return { render: render, resetPage: function() { currentPage = 1; } };
        }

        var pagers = {};
        document.querySelectorAll('.paged-table').forEach(function(table) {
            var p = setupPaging(table.id);
            if (p) { pagers[table.id] = p; p.render(); }
        });

        // Search (Enter)
        document.querySelectorAll('.search-input').forEach(function(input) {
            var tableId = input.dataset.table;
            var tbody = document.getElementById(tableId).querySelector('tbody');
            var useSearchAttr = input.dataset.searchAttr === 'true';
            function doSearch() {
                var term = input.value.toLowerCase();
                tbody.querySelectorAll('tr').forEach(function(row) {
                    var haystack = useSearchAttr ? (row.dataset.search || '').toLowerCase() : row.textContent.toLowerCase();
                    row.dataset.filtered = (!term || haystack.includes(term)) ? 'false' : 'true';
                });
                if (pagers[tableId]) { pagers[tableId].resetPage(); pagers[tableId].render(); }
            }
            input.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
            input.addEventListener('search', doSearch);
        });

        // Sort (3 states)
        document.querySelectorAll('.sortable-table').forEach(function(table) {
            var state = { col: -1, dir: 0 };
            var tbody = table.querySelector('tbody');
            var originalRows = Array.from(tbody.querySelectorAll('tr'));
            function resetArrows(tbl) { tbl.querySelectorAll('.arrow-up, .arrow-down').forEach(function(a) { a.classList.remove('active'); }); }
            table.querySelectorAll('th.sortable').forEach(function(th) {
                th.addEventListener('click', function() {
                    var col = parseInt(this.dataset.col);
                    if (state.col === col) { state.dir = (state.dir + 1) % 3; } else { state.col = col; state.dir = 1; }
                    resetArrows(table);
                    if (state.dir === 0) {
                        originalRows.forEach(function(r) { tbody.appendChild(r); }); state.col = -1;
                    } else {
                        var asc = state.dir === 1;
                        var rows = Array.from(tbody.querySelectorAll('tr'));
                        rows.sort(function(a, b) {
                            var aT = a.cells[col].textContent.trim().toLowerCase(), bT = b.cells[col].textContent.trim().toLowerCase();
                            return aT < bT ? (asc ? -1 : 1) : aT > bT ? (asc ? 1 : -1) : 0;
                        });
                        rows.forEach(function(r) { tbody.appendChild(r); });
                        this.querySelector(asc ? '.arrow-up' : '.arrow-down').classList.add('active');
                    }
                    if (pagers[table.id]) { pagers[table.id].resetPage(); pagers[table.id].render(); }
                });
            });
        });
    });
    </script>
</body>
</html>
