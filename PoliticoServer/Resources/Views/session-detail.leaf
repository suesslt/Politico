<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Politico - #(title)</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f7; color: #1d1d1f; }
        .navbar { background: white; padding: 16px 24px; border-bottom: 1px solid #d2d2d7; display: flex; justify-content: space-between; align-items: center; }
        .navbar h1 { font-size: 20px; }
        .navbar a { color: #0071e3; text-decoration: none; font-size: 14px; }
        .container { max-width: 960px; margin: 24px auto; padding: 0 16px; }
        h2 { font-size: 22px; margin-bottom: 8px; }
        .meta { color: #86868b; font-size: 14px; margin-bottom: 24px; }
        .stats { display: flex; gap: 16px; margin-bottom: 24px; }
        .stat-card { background: white; border-radius: 12px; padding: 16px 20px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); flex: 1; }
        .stat-card .number { font-size: 28px; font-weight: 600; }
        .stat-card .label { color: #86868b; font-size: 14px; }
        h3 { font-size: 18px; margin-bottom: 12px; }
        table { width: 100%; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); border-collapse: collapse; }
        th { background: #f5f5f7; text-align: left; padding: 12px 16px; font-size: 14px; font-weight: 600; border-bottom: 1px solid #d2d2d7; }
        td { padding: 12px 16px; font-size: 14px; border-bottom: 1px solid #f0f0f0; }
        .back-link { display: inline-block; margin-bottom: 16px; color: #0071e3; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>
    <nav class="navbar">
        <h1>Politico</h1>
        <a href="/logout">Abmelden</a>
    </nav>
    <div class="container">
        <a href="/sessions" class="back-link">&larr; Zurück zu Sessions</a>
        <h2>#(title)</h2>
        <p class="meta">#(abbreviation) &middot; #(startDate) - #(endDate)</p>
        <div class="stats">
            <div class="stat-card">
                <div class="number">#(businessCount)</div>
                <div class="label">Geschäfte</div>
            </div>
            <div class="stat-card">
                <div class="number">#(voteCount)</div>
                <div class="label">Abstimmungen</div>
            </div>
        </div>
        <h3>Geschäfte</h3>
        <table>
            <thead>
                <tr>
                    <th>Nr.</th>
                    <th>Titel</th>
                    <th>Typ</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                #for(business in businesses):
                <tr>
                    <td>#(business.shortNumber)</td>
                    <td>#(business.title)</td>
                    <td>#(business.typeName)</td>
                    <td>#(business.statusText)</td>
                </tr>
                #endfor
            </tbody>
        </table>
    </div>
</body>
</html>
