<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wortmeldung - #(speakerFullName)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .prop-row:hover { background-color: #f8f9fa; }
        .prop-text { cursor: text; border: 1px solid transparent; padding: 2px 4px; border-radius: 3px; }
        .prop-text:hover { border-color: #dee2e6; }
        .prop-text:focus { border-color: #86b7fe; outline: none; background: #fff; }
        .prop-text[contenteditable="true"] { min-width: 200px; display: inline-block; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark px-3">
        <span class="navbar-brand">Politico</span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Abmelden</a>
    </nav>

    <div class="container-fluid mt-3">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/sessions" id="backLink">Übersicht</a></li>
                <li class="breadcrumb-item active">#(speakerFullName) - #(meetingDate)</li>
            </ol>
        </nav>
        <script>
        (function() {
            var backURL = '#(backURL)';
            var tabMap = {
                'wortmeldungen': { hash: '#transcripts', label: 'Wortmeldungen' },
                'parlamentarier': { hash: '#members', label: 'Parlamentarier' },
                'geschaefte': { hash: '#businesses', label: 'Geschäfte' }
            };
            var link = document.getElementById('backLink');
            if (tabMap[backURL]) {
                link.href = '/sessions' + tabMap[backURL].hash;
                link.textContent = tabMap[backURL].label;
                sessionStorage.setItem('activeTab', tabMap[backURL].hash);
            }
        })();
        </script>

        <!-- Speaker Info -->
        <div class="d-flex align-items-center mb-3">
            <h4 class="mb-0 me-3">
                #if(speakerID):
                <a href="/members/#(speakerID)?from=wortmeldungen" class="text-decoration-none text-dark">#(speakerFullName)</a>
                #else:
                #(speakerFullName)
                #endif
            </h4>
            <span class="badge me-2" style="background-color:#(partyColor);color:#fff">#(party)</span>
            <span class="text-muted">#(meetingDate)</span>
        </div>

        <!-- Transcript Text -->
        <div class="card mb-4">
            <div class="card-header bg-light"><strong>Wortmeldung</strong></div>
            <div class="card-body" style="max-height:500px;overflow-y:auto">
                #unsafeHTML(htmlText)
            </div>
        </div>

        <!-- Propositions -->
        <div class="card mb-4">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <strong>Propositionen (#(count(propositions)))</strong>
            </div>
            #if(count(propositions) > 0):
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40%">Kernaussage</th>
                            <th style="width:15%">Subjekt</th>
                            <th style="width:12%">Quelle</th>
                            <th style="width:10%">Datum</th>
                            <th style="width:10%"></th>
                        </tr>
                    </thead>
                    <tbody id="propTableBody">
                        #for(prop in propositions):
                        <tr class="prop-row" id="prop-row-#(prop.id)" data-id="#(prop.id)">
                            <td>
                                <span class="prop-text" contenteditable="true" data-field="text" data-id="#(prop.id)">#(prop.text)</span>
                            </td>
                            <td>
                                <select class="form-select form-select-sm" data-field="subjectID" data-id="#(prop.id)" onchange="saveProp(#(prop.id))">
                                    <option value="">-</option>
                                    #for(subject in subjects):
                                    <option value="#(subject.id)" #if(prop.subjectID == subject.id): selected #endif>#(subject.name)</option>
                                    #endfor
                                </select>
                            </td>
                            <td>
                                <span class="prop-text" contenteditable="true" data-field="source" data-id="#(prop.id)">#(prop.source)</span>
                            </td>
                            <td>
                                <span class="prop-text" contenteditable="true" data-field="dateText" data-id="#(prop.id)">#(prop.dateText)</span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-outline-primary btn-sm me-1" onclick="saveProp(#(prop.id))" title="Speichern">&#10003;</button>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteProp(#(prop.id))" title="Löschen">&#10005;</button>
                            </td>
                        </tr>
                        #endfor
                    </tbody>
                </table>
            </div>
            #else:
            <div class="card-body text-muted">Keine Propositionen extrahiert.</div>
            #endif
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    // Save on Enter key in contenteditable fields
    document.querySelectorAll('.prop-text[contenteditable]').forEach(function(el) {
        el.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                saveProp(parseInt(el.dataset.id));
            }
        });
        el.addEventListener('blur', function() {
            saveProp(parseInt(el.dataset.id));
        });
    });

    function saveProp(propId) {
        var row = document.getElementById('prop-row-' + propId);
        if (!row) return;

        var text = row.querySelector('[data-field="text"][data-id="' + propId + '"]').textContent.trim();
        var source = row.querySelector('[data-field="source"][data-id="' + propId + '"]').textContent.trim();
        var dateText = row.querySelector('[data-field="dateText"][data-id="' + propId + '"]').textContent.trim();
        var subjectSelect = row.querySelector('[data-field="subjectID"][data-id="' + propId + '"]');
        var subjectID = subjectSelect.value ? parseInt(subjectSelect.value) : null;

        fetch('/api/propositions/' + propId, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: text, subjectID: subjectID, source: source || null, dateText: dateText || null })
        }).then(function(r) {
            if (r.ok) {
                row.style.transition = 'background-color 0.3s';
                row.style.backgroundColor = '#d4edda';
                setTimeout(function() { row.style.backgroundColor = ''; }, 800);
            } else {
                alert('Fehler beim Speichern');
            }
        });
    }

    function deleteProp(propId) {
        if (!confirm('Proposition wirklich löschen?')) return;
        fetch('/api/propositions/' + propId, { method: 'DELETE' })
            .then(function(r) {
                if (r.ok) {
                    var row = document.getElementById('prop-row-' + propId);
                    if (row) row.remove();
                    // Update count in header
                    var remaining = document.querySelectorAll('#propTableBody tr').length;
                    var header = document.querySelector('.card-header strong');
                    if (header) header.textContent = 'Propositionen (' + remaining + ')';
                } else {
                    alert('Fehler beim Löschen');
                }
            });
    }
    </script>
</body>
</html>
